# ================================================================
# MUSTAFA ACADEMY - Environment Configuration
# ================================================================
# Copy this file to .env and fill in all values
# NEVER commit .env to version control

# ── Application ──────────────────────────────────────────────────
NODE_ENV=production
APP_NAME="Academy Mustafa"
APP_URL=https://academy.example.com
API_URL=https://api.academy.example.com
PORT=3000

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://academy_user:CHANGE_ME@postgres:5432/mustafa_academy?schema=public"
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=2

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL="redis://:CHANGE_ME@redis:6379"
REDIS_PASSWORD=CHANGE_ME

# ── JWT / Auth ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_64_CHARS_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_64_CHARS_RANDOM_DIFFERENT
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
COOKIE_SECRET=CHANGE_ME_32_CHARS

# ── Encryption ───────────────────────────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX
HASH_ROUNDS=12

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Fawry ────────────────────────────────────────────────────────
FAWRY_MERCHANT_CODE=CHANGE_ME
FAWRY_SECURITY_KEY=CHANGE_ME
FAWRY_BASE_URL=https://www.atfawry.com/ECommerceWeb/Fawry/payments
FAWRY_RETURN_URL=https://academy.example.com/payment/callback/fawry

# ── Vodafone Cash ────────────────────────────────────────────────
VODAFONE_MERCHANT_ID=CHANGE_ME
VODAFONE_API_KEY=CHANGE_ME
VODAFONE_BASE_URL=https://api.vodafone.com.eg/payment/v1
VODAFONE_CALLBACK_URL=https://api.academy.example.com/webhooks/vodafone

# ── Mail ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@academy.example.com
SMTP_PASS=CHANGE_ME
MAIL_FROM="أكاديمية مستر مصطفى <noreply@academy.example.com>"

# ── File Storage / S3 ────────────────────────────────────────────
S3_BUCKET=mustafa-academy-media
S3_REGION=me-south-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_CDN_URL=https://cdn.academy.example.com
MAX_FILE_SIZE_MB=500

# ── Monitoring ───────────────────────────────────────────────────
PROMETHEUS_PORT=9090
SENTRY_DSN=https://CHANGE_ME@sentry.io/PROJECT_ID

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=https://academy.example.com,https://admin.academy.example.com

# ── Admin ────────────────────────────────────────────────────────
ADMIN_SEED_EMAIL=admin@academy.example.com
ADMIN_SEED_PASSWORD=CHANGE_ME_STRONG

# ── Queue / BullMQ ───────────────────────────────────────────────
BULL_CONCURRENCY=5
BULL_RETRY_ATTEMPTS=3
BULL_RETRY_DELAY=5000
