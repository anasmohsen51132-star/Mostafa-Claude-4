# ================================================================
# .env.test — API Test Environment
# Used automatically by Vitest via tests/setup.ts
# Never commit real secrets here.
# ================================================================

NODE_ENV=test
PORT=3001

# ── Test Database (separate from dev DB) ─────────────────────────
DATABASE_URL=postgresql://academy_user:testpassword@localhost:5432/academy_test

# ── Redis (same instance, different DB index for isolation) ──────
REDIS_URL=redis://localhost:6379

# ── JWT (short, deterministic test secrets) ──────────────────────
JWT_ACCESS_SECRET=test-access-secret-minimum-32-chars-ok
JWT_REFRESH_SECRET=test-refresh-secret-minimum-32chars!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cookies / Encryption ─────────────────────────────────────────
COOKIE_SECRET=test-cookie-secret-16c
ENCRYPTION_KEY=test-encryption-key-32-chars-here

# ── Hash rounds (low for speed in tests) ─────────────────────────
HASH_ROUNDS=4

# ── Rate limits (high so tests don't trip them) ──────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10000
AUTH_RATE_LIMIT_MAX=10000

# ── Payment providers (mocked in tests via vi.stubGlobal) ────────
STRIPE_SECRET_KEY=sk_test_fake_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_test_fake_webhook_secret
FAWRY_MERCHANT_CODE=TEST_MERCHANT_CODE
FAWRY_SECURITY_KEY=TEST_SECURITY_KEY
FAWRY_BASE_URL=http://localhost:9999/mock-fawry
FAWRY_RETURN_URL=http://localhost:5173/payment/callback/fawry
VODAFONE_MERCHANT_ID=TEST_VODAFONE_ID
VODAFONE_API_KEY=TEST_VODAFONE_KEY
VODAFONE_BASE_URL=http://localhost:9999/mock-vodafone
VODAFONE_CALLBACK_URL=http://localhost:3001/webhooks/vodafone

# ── Storage (use local/mock in tests) ────────────────────────────
S3_BUCKET=test-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY=test-access-key
S3_SECRET_KEY=test-secret-key
S3_CDN_URL=http://localhost:9999/cdn
MAX_FILE_SIZE_MB=10

# ── Mail (disabled in tests) ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Logging (silent in tests) ────────────────────────────────────
LOG_LEVEL=error

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── BullMQ (low retry, fast failure in tests) ────────────────────
BULL_CONCURRENCY=1
BULL_RETRY_ATTEMPTS=1
BULL_RETRY_DELAY=100

# ── App URLs ─────────────────────────────────────────────────────
APP_URL=http://localhost:5173
API_URL=http://localhost:3001

# ── Admin seed (for integration test setup) ──────────────────────
ADMIN_SEED_EMAIL=admin@test.local
ADMIN_SEED_PASSWORD=Admin@TestPass1234
