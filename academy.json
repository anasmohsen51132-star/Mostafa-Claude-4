{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "Mustafa Academy — Platform Overview",
  "uid": "academy-overview",
  "description": "Platform health, payments, enrollments, and API performance",
  "tags": ["academy", "production"],
  "timezone": "Africa/Cairo",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "API Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "up{job=\"academy-api\"}",
        "legendFormat": "API Status"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }]
        }
      }
    },
    {
      "id": 2, "type": "stat", "title": "Request Rate (RPS)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum(rate(http_requests_total{job=\"academy-api\"}[5m]))",
        "legendFormat": "RPS"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } } }
    },
    {
      "id": 3, "type": "stat", "title": "P95 Response Time",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"academy-api\"}[5m])) by (le))",
        "legendFormat": "P95"
      }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] } } }
    },
    {
      "id": 4, "type": "stat", "title": "Error Rate",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum(rate(http_requests_total{job=\"academy-api\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"academy-api\"}[5m])) * 100",
        "legendFormat": "Error %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 5, "type": "stat", "title": "Total Payments (Completed)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "payments_total{status=\"completed\"}",
        "legendFormat": "Payments"
      }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "id": 6, "type": "stat", "title": "Total Enrollments",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "enrollments_total",
        "legendFormat": "Enrollments"
      }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 10, "type": "timeseries", "title": "HTTP Request Rate by Status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "sum(rate(http_requests_total{job=\"academy-api\",status_code=~\"2..\"}[5m]))", "legendFormat": "2xx Success" },
        { "datasource": { "type": "prometheus" }, "expr": "sum(rate(http_requests_total{job=\"academy-api\",status_code=~\"4..\"}[5m]))", "legendFormat": "4xx Client Error" },
        { "datasource": { "type": "prometheus" }, "expr": "sum(rate(http_requests_total{job=\"academy-api\",status_code=~\"5..\"}[5m]))", "legendFormat": "5xx Server Error" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Response Time Percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"academy-api\"}[5m])) by (le))", "legendFormat": "P50" },
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"academy-api\"}[5m])) by (le))", "legendFormat": "P95" },
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"academy-api\"}[5m])) by (le))", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 20, "type": "timeseries", "title": "Payments by Provider",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "sum(rate(payments_total{status=\"completed\"}[5m])) by (provider)", "legendFormat": "{{provider}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 21, "type": "timeseries", "title": "Auth Failures",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "sum(rate(auth_failures_total[5m])) by (reason)", "legendFormat": "{{reason}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 30, "type": "timeseries", "title": "Queue Jobs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "sum(rate(queue_jobs_total[5m])) by (queue, status)", "legendFormat": "{{queue}} — {{status}}" }
      ]
    },
    {
      "id": 31, "type": "timeseries", "title": "Node.js Memory Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "process_resident_memory_bytes{job=\"academy-api\"}", "legendFormat": "RSS Memory" },
        { "datasource": { "type": "prometheus" }, "expr": "nodejs_heap_size_used_bytes{job=\"academy-api\"}", "legendFormat": "Heap Used" },
        { "datasource": { "type": "prometheus" }, "expr": "nodejs_heap_size_total_bytes{job=\"academy-api\"}", "legendFormat": "Heap Total" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
